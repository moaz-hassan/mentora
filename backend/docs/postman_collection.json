{
  "info": {
    "name": "Mentora LMS API - Full Collection",
    "_postman_id": "mentora-lms-full-collection",
    "description": "Postman collection for Mentora backend API. Use {{base_url}} and set {{token}} for authenticated requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"S3cure@123\",\n  \"role\": \"student\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"S3cure@123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login" }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"token\": \"<VERIFICATION_TOKEN>\"\n}" },
            "url": { "raw": "{{base_url}}/auth/verify-email" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.doe@example.com\"\n}" },
            "url": { "raw": "{{base_url}}/auth/forgot-password" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"token\": \"<RESET_TOKEN>\",\n  \"newPassword\": \"NewP@ssw0rd\"\n}" },
            "url": { "raw": "{{base_url}}/auth/reset-password" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/auth/me" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"OldP@ss1\",\n  \"newPassword\": \"NewP@ssw0rd\"\n}" },
            "url": { "raw": "{{base_url}}/auth/change-password" }
          }
        },
        {
          "name": "Resend Verification Email",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/auth/resend-verification-email" }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users (admin)",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users" } }
        },
        {
          "name": "Get User By ID",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/:id", "variable": [ { "key": "id", "value": "1" } ] } }
        },
        {
          "name": "Create User (admin)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"New User\",\n  \"email\": \"new.user@example.com\",\n  \"password\": \"S3cure@123\",\n  \"role\": \"student\"\n}" },
            "url": { "raw": "{{base_url}}/users" }
          }
        },
        {
          "name": "Update User (admin)",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Updated Name\"\n}" },
            "url": { "raw": "{{base_url}}/users/:id", "variable": [ { "key": "id", "value": "1" } ] }
          }
        },
        {
          "name": "Delete User (admin)",
          "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/:id", "variable": [ { "key": "id", "value": "1" } ] } }
        },
        {
          "name": "Become Instructor",
          "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/become-instructor" } }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        { "name": "Get Profile", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/profile" } } },
        { "name": "Update Profile", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\",\n  \"bio\": \"Instructor and developer.\",\n  \"avatar_url\": \"https://example.com/avatar.jpg\",\n  \"headline\": \"Senior Instructor\",\n  \"social_links\": { \"twitter\": \"https://twitter.com/janedoe\" }\n}" }, "url": { "raw": "{{base_url}}/users/profile" } } }
      ]
    },
    {
      "name": "Certificates",
      "item": [
        { "name": "Generate Certificate", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"courseId\": \"<COURSE_ID>\"\n}" }, "url": { "raw": "{{base_url}}/users/certificate/generate" } } },
        { "name": "My Certificates", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/certificate/my" } } },
        { "name": "Check Certificate Exists", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/certificate/check/:courseId", "variable": [ { "key": "courseId", "value": "<COURSE_ID>" } ] } } },
        { "name": "Verify Certificate (public)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/users/certificate/:id/verify", "variable": [ { "key": "id", "value": "<CERT_ID>" } ] } } },
        { "name": "Download Certificate", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/certificate/:id/download", "variable": [ { "key": "id", "value": "<CERT_ID>" } ] } } },
        { "name": "Get Certificate By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/certificate/:id", "variable": [ { "key": "id", "value": "<CERT_ID>" } ] } } },
        { "name": "Admin: List All Certificates", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/users/certificate?student_id=&course_id=&verified=" } } }
      ]
    },
    {
      "name": "Categories",
      "item": [
        { "name": "List Categories", "request": { "method": "GET", "url": { "raw": "{{base_url}}/categories" } } },
        { "name": "Get Category", "request": { "method": "GET", "url": { "raw": "{{base_url}}/categories/:id", "variable": [ { "key": "id", "value": "<CAT_ID>" } ] } } },
        { "name": "Get Subcategories by Category", "request": { "method": "GET", "url": { "raw": "{{base_url}}/categories/:id/subcategories", "variable": [ { "key": "id", "value": "<CAT_ID>" } ] } } },
        { "name": "Create Category (admin)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Programming\"\n}" }, "url": { "raw": "{{base_url}}/categories" } } },
        { "name": "Update Category (admin)", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Name\"\n}" }, "url": { "raw": "{{base_url}}/categories/:id", "variable": [ { "key": "id", "value": "<CAT_ID>" } ] } } },
        { "name": "Delete Category (admin)", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/categories/:id", "variable": [ { "key": "id", "value": "<CAT_ID>" } ] } } }
      ]
    },
    {
      "name": "Subcategories",
      "item": [
        { "name": "List Subcategories", "request": { "method": "GET", "url": { "raw": "{{base_url}}/subcategories" } } },
        { "name": "Get Subcategory", "request": { "method": "GET", "url": { "raw": "{{base_url}}/subcategories/:id", "variable": [ { "key": "id", "value": "<SUBCAT_ID>" } ] } } },
        { "name": "Create Subcategory (admin)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Web Dev\",\n  \"category_id\": \"<CATEGORY_UUID>\"\n}" }, "url": { "raw": "{{base_url}}/subcategories" } } },
        { "name": "Update Subcategory (admin)", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Subcat\"\n}" }, "url": { "raw": "{{base_url}}/subcategories/:id", "variable": [ { "key": "id", "value": "<SUBCAT_ID>" } ] } } },
        { "name": "Delete Subcategory (admin)", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/subcategories/:id", "variable": [ { "key": "id", "value": "<SUBCAT_ID>" } ] } } }
      ]
    },
    {
      "name": "Courses",
      "item": [
        { "name": "List Courses", "request": { "method": "GET", "url": { "raw": "{{base_url}}/courses?page=1&limit=20" } } },
        { "name": "List Featured Courses", "request": { "method": "GET", "url": { "raw": "{{base_url}}/courses/featured" } } },
        { "name": "Search Courses", "request": { "method": "GET", "url": { "raw": "{{base_url}}/courses/search?q=javascript" } } },
        { "name": "Create Course (instructor)", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Intro to Node.js\",\n  \"description\": \"Learn Node.js from scratch\",\n  \"category\": \"Programming\",\n  \"level\": \"beginner\",\n  \"price\": 29.99\n}" }, "url": { "raw": "{{base_url}}/courses" } } },
        { "name": "Update Course Intro Video (instructor)", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"intro_video_url\": \"https://cdn.example.com/videos/intro.mp4\"\n}" }, "url": { "raw": "{{base_url}}/courses/:id/intro-video", "variable": [ { "key": "id", "value": "<COURSE_ID>" } ] } } },
        { "name": "Save Draft (instructor)", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\\n  \\\"draft\\\": true\\n}" }, "url": { "raw": "{{base_url}}/courses/:id/save-draft", "variable": [ { "key": "id", "value": "<COURSE_ID>" } ] } } },
        { "name": "Submit For Review (instructor)", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/:id/submit-review", "variable": [ { "key": "id", "value": "<COURSE_ID>" } ] } } },
        { "name": "Get Related Courses", "request": { "method": "GET", "url": { "raw": "{{base_url}}/courses/:id/related", "variable": [ { "key": "id", "value": "<COURSE_ID>" } ] } } }
      ]
    },
    {
      "name": "Chapters & Lessons",
      "item": [
        { "name": "Create Chapter", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"course_id\": \"<COURSE_ID>\",\n  \"title\": \"Getting Started\",\n  \"description\": \"Intro chapter\"\n}" }, "url": { "raw": "{{base_url}}/courses/chapters" } } },
        { "name": "Update Chapter", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"title\": \"New Chapter Title\"\n}" }, "url": { "raw": "{{base_url}}/courses/chapters/:id", "variable": [ { "key": "id", "value": "<CHAPTER_ID>" } ] } } },
        { "name": "Delete Chapter", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/chapters/:id", "variable": [ { "key": "id", "value": "<CHAPTER_ID>" } ] } } },

        { "name": "Get Lesson by ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/lessons/:id", "variable": [ { "key": "id", "value": "<LESSON_ID>" } ] } } },
        { "name": "Create Lesson", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"chapter_id\": \"<CHAPTER_ID>\",\n  \"title\": \"Intro Lesson\",\n  \"lesson_type\": \"video\",\n  \"content\": \"https://cdn.example.com/video.mp4\",\n  \"duration\": 300\n}" }, "url": { "raw": "{{base_url}}/courses/lessons" } } },
        { "name": "Update Lesson", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Lesson Title\",\n  \"video_url\": \"https://cdn.example.com/newvideo.mp4\"\n}" }, "url": { "raw": "{{base_url}}/courses/lessons/:id", "variable": [ { "key": "id", "value": "<LESSON_ID>" } ] } } },
        { "name": "Delete Lesson", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/lessons/:id", "variable": [ { "key": "id", "value": "<LESSON_ID>" } ] } } }
      ]
    },
    {
      "name": "Lesson Materials",
      "item": [
        { "name": "Add Material to Lesson", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": "<path-to-file>" }, { "key": "title", "value": "Slides" }, { "key": "description", "value": "Lecture slides" } ] }, "url": { "raw": "{{base_url}}/courses/lessons/:lessonId/materials", "variable": [ { "key": "lessonId", "value": "<LESSON_ID>" } ] } } },
        { "name": "Get Lesson Materials", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/lessons/:lessonId/materials", "variable": [ { "key": "lessonId", "value": "<LESSON_ID>" } ] } } },
        { "name": "Delete Material", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/materials/:materialId", "variable": [ { "key": "materialId", "value": "<MATERIAL_ID>" } ] } } },
        { "name": "Update Material Order", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"order\": [ \"mat1\", \"mat2\", \"mat3\" ]\n}" }, "url": { "raw": "{{base_url}}/courses/lessons/:lessonId/materials/order", "variable": [ { "key": "lessonId", "value": "<LESSON_ID>" } ] } } }
      ]
    },
    {
      "name": "Quizzes",
      "item": [
        { "name": "Get Quiz", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/quizzes/:id", "variable": [ { "key": "id", "value": "<QUIZ_ID>" } ] } } },
        { "name": "Create Quiz (instructor)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"chapter_id\": \"<CHAPTER_ID>\",\n  \"title\": \"Quiz 1\",\n  \"questions\": [\n    { \"question\": \"What is 2+2?\", \"options\": [\"A\",\"B\",\"C\",\"D\"], \"answer\": \"A\" }\n  ]\n}" }, "url": { "raw": "{{base_url}}/courses/quizzes" } } },
        { "name": "Update Quiz (instructor)", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Quiz Title\"\n}" }, "url": { "raw": "{{base_url}}/courses/quizzes/:id", "variable": [ { "key": "id", "value": "<QUIZ_ID>" } ] } } },
        { "name": "Delete Quiz", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/quizzes/:id", "variable": [ { "key": "id", "value": "<QUIZ_ID>" } ] } } },
        { "name": "Submit Quiz (student)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"quiz_id\": \"<QUIZ_ID>\",\n  \"score\": 85\n}" }, "url": { "raw": "{{base_url}}/courses/quizzes/submit" } } },
        { "name": "Get Quiz Results (instructor)", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/quizzes/:quizId/results", "variable": [ { "key": "quizId", "value": "<QUIZ_ID>" } ] } } },
