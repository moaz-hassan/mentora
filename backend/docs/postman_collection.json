    {
      "name": "Enrollments",
      "item": [
        { "name": "List Enrollments", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/enrollments" } } },
        { "name": "Check Enrollment", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{base_url}}/courses/enrollments/check/:courseId", "variable": [ { "key": "courseId", "value": "<COURSE_ID>" } ] } } },
