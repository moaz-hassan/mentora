        { "name": "Delete Review", "request": { "method": "DELETE", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\n  \"review_id\": \"<REVIEW_ID>\"\n}" }, "url": { "raw": "{{base_url}}/courses/reviews" } } }
