# Mentora backend — example environment variables
# Copy this file to `.env` and fill real values. DO NOT commit secrets.

# --- App ---
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# --- Database (MySQL / Sequelize) ---
DB_NAME=mentora
DB_USER=root
DB_PASS=0000
DB_HOST=localhost
DB_PORT=3306
DB_SSL=false

# --- Redis (ioredis) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT / Auth ---
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=7d

# --- Mailer (Gmail SMTP) ---
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Supabase (optional - certificates & materials) ---
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_CERTIFICATES_BUCKET=certificates
SUPABASE_MATERIALS_BUCKET=materials

# --- AI / Gemini (optional) ---
GEMINI_API_KEY=your_gemini_api_key

# --- Optional / Integrations ---
# SENTRY_DSN=
# LOG_LEVEL=info
# STRIPE_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=

# Notes:
# - Fill these values before running the app.
# - For production, store secrets in a secret manager and do NOT commit `.env`.
